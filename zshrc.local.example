# ~/.zshrc.local にコピーして値を設定してください
# このファイルはgit管理されません

# SSH Agent ソケットパス（マシン固有）
export SSH_AUTH_SOCK=~/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock

# GitHub PATs
export GH_TOKEN_CW_WORKSPACE=your_token_here
export GH_TOKEN_CW_CODE_REPOS=your_token_here

# Anthropic API key
export ANTHROPIC_AUTH_TOKEN=your_key_here
